# ── Core ──────────────────────────────────────────────────────
# Required for AI negotiation advice
ANTHROPIC_API_KEY=your_key_here

# ── Reddit (optional) ─────────────────────────────────────────
# App works without these — falls back to seed/community data
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=haggle-app/1.0

# ── WhatsApp (choose one provider) ────────────────────────────
# Set WHATSAPP_PROVIDER to either "twilio" or "meta"
WHATSAPP_PROVIDER=twilio

# Twilio (easiest for dev — free sandbox)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Meta Cloud API (free for production, 1000 convos/month free)
META_WHATSAPP_TOKEN=your_meta_access_token
META_PHONE_NUMBER_ID=your_phone_number_id
META_VERIFY_TOKEN=haggle_verify   # any string you choose
